---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';

const contacts = [
  ['Email', '12313231@mail.sustech.edu.cn', 'mailto:12313231@mail.sustech.edu.cn'],
  ['GitHub', 'github.com/zceeeeee', 'https://github.com/zceeeeee']
];
---

<BaseLayout title="Contact" description="联系朱成毅 / Max Zhu，讨论科研合作、实习机会和技术交流。">
  <section class="container page-hero">
    <p class="eyebrow">Contact</p>
    <h1>联系我</h1>
    <p>I'm open to research collaboration, internship opportunities, and technical discussions.</p>
  </section>

  <section class="container section">
    <SectionHeading title="Links" description="公开联系方式暂保留邮箱和 GitHub。" />
    <div class="grid grid-2">
      {contacts.map(([label, value, href]) => (
        <a class="contact-card" href={href}>
          <h3>{label}</h3>
          <p>{value}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
