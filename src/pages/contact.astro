---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<BaseLayout title="Contact" description="联系朱成毅 / Max Zhu，讨论科研合作、实习机会和技术交流。">
  <section class="container page-hero">
    <p class="eyebrow">Contact</p>
    <h1>联系我</h1>
    <p>I'm open to research collaboration, internship opportunities, and technical discussions.</p>
  </section>

  <section class="container section">
    <SectionHeading title="Contact" description="欢迎通过邮箱或 GitHub 联系我。" />
    <div class="grid grid-2">
      <div class="contact-card">
        <h3>Email</h3>
        <p>12313231@mail.sustech.edu.cn</p>
      </div>
      <a class="contact-card" href="https://github.com/zceeeeee">
        <h3>GitHub</h3>
        <p>github.com/zceeeeee</p>
      </a>
    </div>
  </section>
</BaseLayout>
