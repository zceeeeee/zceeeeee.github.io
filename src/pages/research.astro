---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';

const projects = [
  {
    title: 'SAW-AlN 换能器仿真与测试',
    description: '围绕 AlN 基 IDT 声表面波器件，结合 COMSOL 仿真与 VNA 测试，分析器件频率响应和探针结构对高频测量的影响。'
  },
  {
    title: 'QLED / OLED / QD 发光器件制备与表征测试',
    description: '关注发光器件制备、材料 / 器件表征与实验数据分析，训练从实验流程到结果解释的完整科研工作方式。'
  }
];
---

<BaseLayout title="Research" description="朱成毅 / Max Zhu 的研究兴趣：光电子器件、声表面波器件、发光器件制备与表征、器件仿真和实验测试。">
  <section class="container page-hero">
    <p class="eyebrow">Research</p>
    <h1>科研兴趣</h1>
    <p>我的研究兴趣集中在光电子器件、声表面波器件、发光器件制备与表征，以及器件仿真和实验测试流程。</p>
  </section>

  <div class="container page-grid">
    <aside class="side-note">Research focus: optoelectronic devices, device simulation, RF measurement, and experimental data analysis.</aside>
    <div>
      <section class="page-section">
        <SectionHeading title="Research Interests" />
        <div class="grid grid-2">
          <div class="info-block">
            <h3>光电子与声表面波器件</h3>
            <p>关注器件结构、材料属性、仿真建模、测试流程和实验数据解释。</p>
          </div>
          <div class="info-block">
            <h3>发光器件制备与表征</h3>
            <p>关注 QLED、OLED、QD 等发光器件的制备过程、表征测试与数据分析。</p>
          </div>
        </div>
      </section>

      <section class="page-section">
        <SectionHeading title="Research Projects" />
        <div class="grid grid-2">
          {projects.map((project) => (
            <div class="info-block">
              <h3>{project.title}</h3>
              <p>{project.description}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="page-section">
        <SectionHeading title="Methods & Tools" />
        <div class="grid grid-2">
          <div class="info-block">
            <h3>Simulation</h3>
            <p>使用 COMSOL 进行多物理场建模、特征频率分析和频域响应分析。</p>
          </div>
          <div class="info-block">
            <h3>Measurement</h3>
            <p>结合 VNA、探针台和实验数据处理流程，分析器件响应与测试结构影响。</p>
          </div>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
