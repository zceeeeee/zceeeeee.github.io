---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import ButtonLink from '../components/ButtonLink.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';

const projects = await getCollection('projects');
const blog = await getCollection('blog', ({ data }) => !data.draft);
const featuredProjects = projects
  .filter((project) => project.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const recentNotes = blog.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);

const interests = [
  ['光电子器件', '关注器件仿真、实验测试与表征分析，逐步建立从物理模型到实验数据的理解。'],
  ['嵌入式系统', '围绕传感器、硬件接口、实时约束和系统调试，完成电子系统原型设计。'],
  ['计算机视觉', '在课程项目和工程实践中使用视觉模块、图像处理和实验评估方法。'],
  ['AI 工具应用', '将 AI 辅助工具用于工程记录、代码实现、数据整理和学习流程优化。'],
  ['电子系统原型设计', '把课程、竞赛和科研训练中的想法落到可测试、可复盘的系统里。']
];
---

<BaseLayout title="朱成毅 / Max Zhu" description="南方科技大学电子系本科生，关注光电子器件、嵌入式系统、计算机视觉与 AI 工具应用。">
  <section class="container hero">
    <div>
      <p class="eyebrow">Engineering Portfolio</p>
      <h1>朱成毅 / Max Zhu</h1>
      <p>南方科技大学电子系本科生，关注光电子器件、嵌入式系统、计算机视觉与 AI 工具应用。</p>
      <div class="button-row">
        <ButtonLink href="/projects">View Projects</ButtonLink>
        <ButtonLink href="/resume.pdf" variant="secondary" download>Download CV</ButtonLink>
        <ButtonLink href="https://github.com/zceeeeee" variant="ghost">GitHub</ButtonLink>
        <ButtonLink href="mailto:12313231@mail.sustech.edu.cn" variant="ghost">Email</ButtonLink>
      </div>
    </div>
    <aside class="hero-panel" aria-label="Profile summary">
      <dl>
        <div>
          <dt>Current Identity</dt>
          <dd>南方科技大学 2027 届本科生，电子系，光电信息与技术方向。</dd>
        </div>
        <div>
          <dt>Current Focus</dt>
          <dd>电子创新课程密室逃脱项目、嘉立创杯、电子设计竞赛与光电子器件相关科研训练。</dd>
        </div>
        <div>
          <dt>Open to</dt>
          <dd>Research collaboration, internship opportunities, and technical discussions.</dd>
        </div>
      </dl>
    </aside>
  </section>

  <section class="container section">
    <SectionHeading eyebrow="Interests" title="Research / Technical Interests" description="围绕光电器件、嵌入式系统、计算机视觉和 AI 工具应用，持续积累课程项目、科研训练与工程实践经验。" />
    <div class="grid grid-3">
      {interests.map(([title, description]) => (
        <article class="interest-card">
          <h3>{title}</h3>
          <p>{description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container section">
    <SectionHeading eyebrow="Selected Work" title="Featured Projects" description="这里保留代表项目入口；具体项目细节可在后续补充时间、技术栈、个人贡献和结果展示。" />
    {featuredProjects.length > 0 ? (
      <div class="grid grid-3">
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    ) : (
      <p class="empty-state">项目内容待补充。</p>
    )}
  </section>

  <section class="container section">
    <SectionHeading eyebrow="Knowledge Base" title="Recent Notes" description="技术笔记可后续补充，例如 COMSOL 仿真流程、Maxicam2 项目复盘、GitHub Pages 部署记录。" />
    {recentNotes.length > 0 ? (
      <div class="grid grid-3">
        {recentNotes.map((post) => <BlogCard post={post} />)}
      </div>
    ) : (
      <p class="empty-state">博客与技术笔记暂未展开。</p>
    )}
  </section>

  <section class="container section">
    <SectionHeading eyebrow="Links" title="Find me online" />
    <div class="link-list">
      <a href="https://github.com/zceeeeee">GitHub</a>
      <a href="mailto:12313231@mail.sustech.edu.cn">Email</a>
      <a href="/cv">CV</a>
    </div>
  </section>
</BaseLayout>
