---
import Tag from './Tag.astro';

interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      description: string;
      date: Date;
      tags: string[];
      category: string;
    };
  };
}

const { post } = Astro.props;
const formattedDate = post.data.date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---

<article class="card blog-card">
  <div class="card-meta">
    <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
    <span>{post.data.category}</span>
  </div>
  <h3><a href={`/blog/${post.slug}`}>{post.data.title}</a></h3>
  <p>{post.data.description}</p>
  <div class="tag-list">
    {post.data.tags.map((tag) => <Tag label={tag} />)}
  </div>
</article>
